# =============================================================
# Pinterest MCP server configuration
# Copy to .env (gitignored) and fill in. NEVER commit a populated
# .env or paste live tokens into any committed file.
# =============================================================

# --- OAuth mode (recommended, 30 day access tokens + auto refresh) ---
# From https://developers.pinterest.com/apps/ on your app page.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Must match a redirect URI registered on the Pinterest app.
# Default below is what 'npm run auth' listens on locally.
PINTEREST_REDIRECT_URI=http://localhost:8788/callback

# --- One-shot mode (sandbox or trial tokens, 24h lifetime) ---
# If set, the server uses this directly and skips OAuth/refresh.
PINTEREST_ACCESS_TOKEN=

# --- Optional ---
# Override the default token storage location.
# Defaults to ~/.config/claude-pinterest/tokens.json
PINTEREST_TOKEN_PATH=

# Defaults to https://api.pinterest.com. Set to
# https://api-sandbox.pinterest.com to hit the sandbox.
PINTEREST_API_BASE=
